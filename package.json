		"@types/jest": "^30.0.0",
		"@types/node": "^24.2.0",
		"eslint": "^9.32.0",
		"jest": "^30.0.5",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.4.1",
		"ts-node": "^10.9.2",
		"tsup": "^8.5.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.1"
	}
