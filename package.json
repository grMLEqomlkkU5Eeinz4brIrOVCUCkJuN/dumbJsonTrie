{
	"name": "trie",
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"dev": "ts-node src/index.ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"benchmark": "node --expose-gc -r ts-node/register benchmark/benchmark.ts",
		"benchmarkip": "node --expose-gc -r ts-node/register benchmark/ip-bench.ts",
		"example:basic": "ts-node examples/basic-example.ts",
		"example:streaming": "ts-node examples/file-streaming-example.ts",
		"clean": "rimraf dist/",
		"prepublishOnly": "npm run clean && npm run build && npm test",
		"prepack": "npm run build"
	},
	"keywords": [],
	"author": "",
